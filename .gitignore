# =============================================================
# Wind Turbine Predictive Maintenance — .gitignore
# =============================================================

# ----- Python -----
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ----- Virtual Environments -----
.env
.envrc
.venv/
venv/
env/

# ----- Data (large binary files — not for version control) -----
data/
*.mat
*.h5
*.hdf5

# ----- Logs -----
logs/
*.log

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Project Report (binary document) -----
BitirmeAraRapor.docx
BitirmeAraRapor_extracted.txt

# ----- Test / Coverage -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ----- Type Checking / Linting -----
.mypy_cache/
.ruff_cache/
.pytype/

# ----- Distribution / Packaging -----
*.manifest
*.spec
MANIFEST
wheels/
