# =============================================================
# Wind Turbine — Environment Variables
# cp .env.example .env  →  değerleri doldurun
# =============================================================

# Bilgisayarın lokal IP'si  →  ipconfig | findstr IPv4
MQTT_HOST=192.168.1.xxx

MQTT_USER=jetson-wt001
MQTT_PASSWORD=guclu_bir_sifre

# ca.crt'nin yolu:
#   Lokal (PC'de test): ./certs/ca.crt
#   Jetson üzerinde:    /home/jetson/certs/ca.crt
MQTT_CA_CERT_PATH=./certs/ca.crt

DB_PASSWORD=guclu_bir_db_sifresi
